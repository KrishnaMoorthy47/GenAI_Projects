# ── Auth ──────────────────────────────────────────────────────────
API_KEY=dev-secret

# ── LLM ───────────────────────────────────────────────────────────
# Provider: "openai" or "azure_openai"
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Azure OpenAI (only needed if LLM_PROVIDER=azure_openai)
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-08-01-preview
# AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ── LangSmith ─────────────────────────────────────────────────────
# Get your key at: https://smith.langchain.com → Settings → API Keys
LANGSMITH_API_KEY=lsv2_pt_your_langsmith_api_key_here
LANGSMITH_PROJECT=agenteval
# Set to "true" to trace every LLM call to LangSmith
LANGSMITH_TRACING=true

# ── App ───────────────────────────────────────────────────────────
PORT=8003
DB_PATH=data/tamil_songs.db

GROQ_API_KEY=gsk_your_groq_api_key_here
